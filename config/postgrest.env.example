# PostgREST ortam değişkenleri (isteğe bağlı)
# Kopyala: cp config/postgrest.env.example .env.postgrest
# Kullanım: env $(cat .env.postgrest | xargs) postgrest config/postgrest.conf

# Veritabanı connection string (postgres://user:pass@host:port/dbname)
PGRST_DB_URI=postgres://postgres:Yq7xwQpt6c@127.0.0.1:5432/retailex_local

# Anon rol (PostgreSQL'de oluşturulmuş olmalı; yoksa postgres kullanın)
PGRST_DB_ANON_ROLE=anon

# Açılacak şemalar
PGRST_DB_SCHEMAS=public,logic,wms,rest,beauty,pos,logistics

# Sunucu portu
PGRST_SERVER_PORT=3002

# JWT secret (production'da 32+ karakter; JWT kullanacaksanız açın)
# PGRST_JWT_SECRET=reallyreallyreallyreallyverysafe
