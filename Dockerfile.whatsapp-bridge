# RetailEX Baileys WhatsApp köprüsü — GET /status, POST /send (:3000)
FROM node:22-alpine
WORKDIR /app

COPY scripts/whatsapp-bridge/package.json scripts/whatsapp-bridge/package-lock.json ./
RUN npm ci --omit=dev

COPY scripts/whatsapp-bridge/server.mjs ./

ENV NODE_ENV=production
ENV WA_BRIDGE_PORT=3000
ENV WA_BRIDGE_AUTH_DIR=/data/.wa-auth

VOLUME ["/data"]
EXPOSE 3000

CMD ["node", "server.mjs"]
