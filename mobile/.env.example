# Örnek — gerçek değerleri .env'e kopyalayın (commit etmeyin)
# Fiziksel cihaz: Bridge host = PC LAN IP (192.168.x.x)
EXPO_PUBLIC_BRIDGE_HOST=10.0.2.2
# Varsayılan 3001. Terazi/scale için güncel Node bridge gerekir.
# Eski Windows RetailEX_SQL_Bridge 3001'deyse (scale routes yok):
#   köke BRIDGE_PORT=3002 npm run bridge → burada / Config'de 3002
# EXPO_PUBLIC_BRIDGE_PORT=3002
EXPO_PUBLIC_BRIDGE_PORT=3001
# PG host bridge makinesine göredir (aynı PC'de PG → 127.0.0.1)
EXPO_PUBLIC_PG_HOST=127.0.0.1
EXPO_PUBLIC_PG_PORT=5432
EXPO_PUBLIC_PG_DATABASE=retailex_local
EXPO_PUBLIC_PG_USER=postgres
# EXPO_PUBLIC_PG_PASSWORD=
# EXPO_PUBLIC_DB_MODE=local

# PostgREST (web remote_rest_url) — Config ekranından da kaydedilir (AsyncStorage)
# EXPO_PUBLIC_REMOTE_REST_URL=https://api.retailex.app/tenant
# EXPO_PUBLIC_POSTGREST_ANON_KEY=
# EXPO_PUBLIC_API_MODE=bridge

# EAS Build / Submit (isteğe bağlı — headless/CI; yerelde eas login yeterli)
# https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_TOKEN=
#
# Google Play service account JSON — dosya yolu (içerik .env'e yapıştırılmaz; commit yok)
# Varsayılan path: mobile/secrets/google-play-service-account.json (gitignore)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
# Ayrıntı: PLAY_SUBMIT.md
