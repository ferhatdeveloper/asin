# Bölge (yedek): Veritabanında aktif firma için `firms.regulatory_region` önceliklidir;
# Sistem Yönetimi → Firma/Dönem → firma kartı → Mevzuat / e-Belge.
# Env yalnızca PG/Tauri yoksa veya test için: TR = GİB ekranı
# VITE_REGULATORY_REGION=TR

# GİB: geliştirme mock taşıyıcı — entegratör bilgisi firma kartında (Sistem Yönetimi → Firma → E-Fatura entegrasyonu)
# VITE_GIB_MOCK_TRANSPORT=true

# Pexels API Key for image search feature
# Get your free API key from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# pg_bridge (npm run bridge) — Caller ID webhook koruması (isteğe bağlı)
# PowerShell örneği: $env:CALLER_ID_PUSH_TOKEN="uzun-gizli-deger"
# Aynı değeri Restoran Ayarlar > Arayan No > API token alanına yazın.
# CALLER_ID_PUSH_TOKEN=

# pg_bridge — Yemeksepeti / Getir / entegratörden paket siparişi push (isteğe bağlı)
# DELIVERY_PUSH_TOKEN=

# Frontend/DeskApp bridge adresi (opsiyonel, otomatik algılamayı override eder)
# Örnek: VITE_BRIDGE_URL=http://127.0.0.1:3001
# VITE_BRIDGE_URL=

# merkez_db PostgREST taban URL (Login → kiracı çözümleme). Boşsa tarayıcıda :3002 veya localStorage merkez_postgrest_base_url kullanılır.
# Örnek: VITE_MERKEZ_REST_URL=http://berqenas.cloud:3002
# VITE_MERKEZ_REST_URL=

# --- Docker / Dokploy (docker-compose.dokploy.yml) — tam PostgreSQL yedek ---
# Köprü: PG_DUMP_TOKEN — Frontend build: VITE_PG_DUMP_TOKEN (aynı değer). Ayrıntı: docker/dokploy.env.example
# PG_DUMP_TOKEN=
# VITE_PG_DUMP_TOKEN=
# PostgREST ile aynı iç PostgreSQL (api:443 TLS hatasını önler): köprüde PG_DUMP_INTERNAL_URI
# PG_DUMP_INTERNAL_URI=postgres://postgres:PAROLA@postgres:5432
# PG_DUMP_ALLOWED_DBS=tenant_db_1,tenant_db_2
# VITE_PG_DUMP_INTERNAL=   # boş=otomatik; 1=yalnız iç pg_dump; 0=yalnız harici connStr
# PG_DUMP_PATH=
# BRIDGE_PORT=3001

# --- Uzak bağlantı (hibrit: yerel PG + uzak PostgREST) ---
# Tek kaynak: config/remote-pg.defaults.json
# Varsayılan: connection_provider=rest_api, remote_rest_url=https://api.retailex.app/{kiracı_kodu}
# Örnek kiracı URL: https://api.retailex.app/berzin_com
# VITE_MERKEZ_REST_URL=https://api.retailex.app/merkez
