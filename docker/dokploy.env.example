# Dokploy / docker-compose.dokploy.yml için örnek ortam
# Bu dosyayı repoya gerçek şifre/token yazmadan tutun. Dokploy arayüzünde Secrets / Environment olarak girin.
#
# Mevcut veritabanı volume’larına veya init script’lere dokunmaz; yalnızca çalışma anı ve build arg’ları etkiler.

# --- PostgreSQL (zorunlu) ---
POSTGRES_PASSWORD=ornek_guclu_sifre_degistirin

# --- pg_bridge: Sistem ayarları → PostgreSQL tam yedek ---
# Üretimde mutlaka dolu tutun; köprü ile frontend build’de AYNI değer olmalı.
# Örnek üretim: openssl rand -hex 32
PG_DUMP_TOKEN=
# Frontend Vite build sırasında bundle’a gider — PG_DUMP_TOKEN ile birebir aynı olmalı.
VITE_PG_DUMP_TOKEN=
# PostgREST ile aynı Docker postgres (köprü /api/pg_dump_internal — api:443 TLS sorununu çözer)
PG_DUMP_INTERNAL_URI=postgres://postgres:PAROLA@postgres:5432
# İsteğe bağlı: yalnız bu DB adlarına izin (virgülle). Boş = güvenli isim kalıbı.
# PG_DUMP_ALLOWED_DBS=berzin_com,merkez_db
# Frontend: 1=yalnız iç yol; 0=yalnız harici connStr; boş=otomatik (api:443 / rest_api → iç)
# VITE_PG_DUMP_INTERNAL=

# İsteğe bağlı: pg_dump yolu (Alpine bridge imajında genelde boş bırakın)
# PG_DUMP_PATH=

BRIDGE_PORT=3001

# --- WhatsApp Baileys köprüsü (retailex_whatsapp_bridge) ---
# Dokploy: main redeploy veya terminalde dokploy-redeploy-whatsapp.sh
# Backoffice QR paneli: Köprü URL = /__wa_bridge (nginx → retailex_whatsapp_bridge:3000)
# WA_BRIDGE_TOKEN=   # doluysa Authorization: Bearer zorunlu (messaging ayarlarında da girin)
# Oturum dosyaları: named volume retailex_wa_bridge_data

# --- WebSocket Sync (sync_lovan, sync_kasap, … + api_gateway Caddy) ---
# Önkoşul: kiracı DB’lerde 075_tenant_websocket_hub.sql (npm run db:migrate:tenants)
# Dokploy terminal: POSTGRES_PASSWORD='...' bash database/scripts/dokploy-redeploy-sync.sh
# Dış test: curl -s https://api.retailex.app/lovan/sync/health

# --- Dokploy deploy ipuçları ---
# Tam Redeploy uzun sürer (16 sync imajı paralel). UI-only güncelleme:
#   POSTGRES_PASSWORD='...' bash database/scripts/dokploy-redeploy-frontend.sh
# Build OOM / sarıda takılma: sunucuda en az 4 GB boş RAM; COMPOSE_PARALLEL_LIMIT=2
# Vite log: "rendering chunks..." normaldir, 2–5 dk sürebilir.

# --- pg_bridge diğer uçlar (isteğe bağlı) ---
# CALLER_ID_PUSH_TOKEN=
# DELIVERY_PUSH_TOKEN=

# --- İsteğe bağlı portlar / URL ---
# POSTGRES_PORT=5432
# RETAILEX_WEB_PORT=8080
# VITE_MERKEZ_REST_URL=https://api.retailex.app/merkez

# pgAdmin (varsayılanları değiştirin)
# PGADMIN_DEFAULT_EMAIL=admin@ornek.local
# PGADMIN_DEFAULT_PASSWORD=ornek_degistirin
