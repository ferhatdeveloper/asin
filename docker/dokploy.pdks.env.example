# Dokploy → PDKS projesi → Compose servisi → Environment
# Gerçek şifreleri buraya yazıp commit etmeyin; yalnız Dokploy Secrets’a girin.

# Uzak PostgreSQL (firmalar.connection_config)
PDKS_PG_HOST=91.205.41.130
PDKS_PG_PORT=5432
PDKS_PG_USER=postgres
PDKS_PG_PASSWORD=DEGISTIRIN

# Veritabanı adları (uzak sunucudaki birebir ad)
PDKS_DB_NAW=NAW_PDKS
PDKS_DB_EXFIN=EXFIN_PDKS

# PostgREST (PDKS şemasında anon yoksa postgres kullanın)
PDKS_PGRST_ANON_ROLE=postgres
PDKS_PGRST_SCHEMAS=public

# xNAWCOMREST uzak REST
PDKS_REMOTE_REST_HOST=91.205.41.130
PDKS_REMOTE_REST_PORT=8000

# Host portları (Dokploy domain kullanıyorsanız isteğe bağlı)
PDKS_API_HOST_PORT=8100
PDKS_POSTGREST_PORT_NAW=3110
PDKS_POSTGREST_PORT_EXFIN=3111
