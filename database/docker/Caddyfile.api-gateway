    handle /retailex_demo/sync/* {
        uri strip_prefix /retailex_demo/sync
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_retailex_demo:8080
    }
    handle_path /retailex_demo/* {
        header Access-Control-Allow-Origin "https://retailex.app"
