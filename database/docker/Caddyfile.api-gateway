:80 {
    encode gzip

    @preflight method OPTIONS
    header @preflight Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS"
    header @preflight Access-Control-Allow-Headers "Authorization,Content-Type,apikey,Prefer,Accept,Origin,Content-Profile,Accept-Profile"
    header @preflight Access-Control-Max-Age "86400"
    header @preflight Access-Control-Allow-Origin "*"
    handle @preflight {
        respond 204
    }

    @health path / /health /status
    handle @health {
        header Content-Type "application/json; charset=utf-8"
        respond "{\"ok\":true,\"service\":\"retailex-api-gateway\"}" 200
    }

    handle_path /merkez/* {
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy postgrest_merkez:3000 {
            header_down -Access-Control-Allow-Origin
            header_down Access-Control-Allow-Origin "https://retailex.app"
        }
    }

    handle /aqua/ws* {
        uri strip_prefix /aqua
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_aqua:8080
    }
    handle /aqua/sync/* {
        uri strip_prefix /aqua/sync
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_aqua:8080
    }
    handle_path /aqua/* {
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy postgrest_aqua_beauty:3000 {
            header_down -Access-Control-Allow-Origin
            header_down Access-Control-Allow-Origin "https://retailex.app"
        }
    }

    handle /siti_pdks/ws* {
        uri strip_prefix /siti_pdks
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_siti_pdks:8080
    }
    handle /siti_pdks/sync/* {
        uri strip_prefix /siti_pdks/sync
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_siti_pdks:8080
    }
    handle_path /siti_pdks/* {
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy postgrest_siti_pdks:3000 {
            header_down -Access-Control-Allow-Origin
            header_down Access-Control-Allow-Origin "https://retailex.app"
        }
    }

    handle /pdks_demo/ws* {
