    handle /ozbek/ws* {
        uri strip_prefix /ozbek
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_ozbek:8080
    }
    handle /ozbek/sync/* {
        uri strip_prefix /ozbek/sync
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy sync_ozbek:8080
    }
    handle_path /ozbek/* {
        header Access-Control-Allow-Origin "https://retailex.app"
        reverse_proxy postgrest_ozbek:3000 {
            header_down -Access-Control-Allow-Origin
            header_down Access-Control-Allow-Origin "https://retailex.app"
        }
    }

    handle {
        header Content-Type "application/json; charset=utf-8"
        respond "{\"ok\":false,\"error\":\"not_found\"}" 404
    }
}
