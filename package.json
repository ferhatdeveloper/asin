    "desktop:ci:portable": "node scripts/trigger-desktop-portable-release.mjs",
    "brand:icons": "node scripts/generate-asin-brand-assets.mjs",
    "desktop:ci:cleanup": "node scripts/cleanup-github-desktop-releases.mjs",
    "tauri:windows-signing:example": "node -e \"const fs=require('fs');const p='DeskApp/tauri.windows.conf.json';if(fs.existsSync(p))throw new Error(p+' zaten var');fs.copyFileSync('DeskApp/tauri.windows.conf.json.example',p);console.log(p+' olusturuldu; certificateThumbprint doldurun.');\"",
