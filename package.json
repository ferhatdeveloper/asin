    "dev:with-bridge": "npx --yes concurrently -k -n bridge,vite -c blue,green \"npm run bridge\" \"npm run dev\"",
    "dev:with-wa": "npx --yes concurrently -k -n wa,vite -c magenta,green \"npm run whatsapp:bridge\" \"npm run dev\"",
